---
extends: default
rules:
  braces:
    max-spaces-inside: 1
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  line-length:
    max: 160
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy:
    check-keys: true
    allowed-values: ["true", "false", "on"]
  document-start: disable

ignore: |
  .ansible/
  dotfiles/.codex/.tmp/
