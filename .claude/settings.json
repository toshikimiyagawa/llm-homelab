{
  "permissions": {
    "allow": [
      "Bash(ansible-playbook *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "vendor/ai-sdd-guide/integration/hooks/sdd-guard.sh"
          },
          {
            "type": "command",
            "command": "vendor/ai-sdd-guide/integration/hooks/skill-reminder.sh"
          }
        ]
      }
    ]
  }
}
